{
  "name": "task-manager-ts",
  "version": "1.0.0",
  "description": "Sistema de Gestión de Tareas - Sprint TypeScript Avanzado Semana 1",
  "main": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test",
    "test:types": "tsd",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-coverage": "type-coverage --at-least 95"
  },
  "keywords": [
    "typescript",
    "generics",
    "type-safety",
    "learning"
  ],
  "author": "Aldo",
  "license": "MIT",
  "tsd": {
    "directory": "tests"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "tsd": "^0.30.0",
    "tsx": "^4.21.0",
    "type-coverage": "^2.27.0",
    "typescript": "^5.3.0"
  }
}
